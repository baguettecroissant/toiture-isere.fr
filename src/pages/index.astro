  <!-- Snow Simulator Script Logic -->
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const altSlider = document.getElementById('simulator-alt') as HTMLInputElement;
      const slopeSlider = document.getElementById('simulator-slope') as HTMLInputElement;
      const altVal = document.getElementById('simulator-alt-val');
      const slopeVal = document.getElementById('simulator-slope-val');
      const windRadios = document.getElementsByName('simulator-wind') as NodeListOf<HTMLInputElement>;
      const resultDiv = document.getElementById('simulator-result');
      const adviceP = document.getElementById('simulator-advice');

      const calculate = () => {
        if (!altSlider || !slopeSlider || !resultDiv || !adviceP) return;

        const alt = Number(altSlider.value);
        const slope = Number(slopeSlider.value);
        if (altVal) altVal.textContent = `${alt} m`;
        if (slopeVal) slopeVal.textContent = `${slope} °`;

        let windMult = 1;
        for (const radio of windRadios) {
          if ((radio as HTMLInputElement).checked) {
            windMult = Number((radio as HTMLInputElement).value);
            break;
          }
        }

        // Snow C2 basic load simulation
        // Base load increases with altitude:
        // alt < 200: 60 kg/m2
        // alt 200 - 500: 60 + 0.1 * (alt - 200)
        // alt > 500: 90 + 0.15 * (alt - 500)
        let baseLoad = 60;
        if (alt > 200 && alt <= 500) {
          baseLoad = 60 + 0.1 * (alt - 200);
        } else if (alt > 500) {
          baseLoad = 90 + 0.18 * (alt - 500);
        }

        // Pente multiplier (Eurocodes slope coefficient)
        // slope < 30: multiplier = 1
        // slope > 60: multiplier = 0
        // slope 30 to 60: linear reduction
        let slopeMult = 1;
        if (slope > 30 && slope < 60) {
          slopeMult = 1 - (slope - 30) / 30;
        } else if (slope >= 60) {
          slopeMult = 0.1;
        }

        const requiredCapacity = Math.round(baseLoad * slopeMult * windMult);
        resultDiv.textContent = `${requiredCapacity} kg/m²`;

        // Local advice
        if (alt >= 1000) {
          adviceP.innerHTML = `<strong>⚠️ Haute Altitude :</strong> Zone C2 sévère. Charpente Eurocode 5 et isolation par Sarking recommandées. Crochets d'arrêt de neige en acier ou inox indispensables.`;
        } else if (alt >= 500) {
          adviceP.innerHTML = `<strong>⚠️ Moyenne Montagne :</strong> Zone C2 modérée. Crochets arrêts de neige nécessaires pour limiter les risques de glissement.`;
        } else {
          adviceP.innerHTML = `<strong>✓ Zone de Plaine :</strong> Conditions de plaine standard. Norme de ventilation DTU 40.21 préconisée pour réguler l'humidité.`;
        }
      };

      // Listeners
      altSlider?.addEventListener('input', calculate);
      slopeSlider?.addEventListener('input', calculate);
      windRadios.forEach(r => r.addEventListener('change', calculate));

      // Initial run
      calculate();
    });

    // Suble Snow Particles Generator
    const snowOverlay = document.getElementById('snow-overlay');
    if (snowOverlay) {
      const flakeCount = 35;
      for (let i = 0; i < flakeCount; i++) {
        const flake = document.createElement('div');
        flake.classList.add('snowflake');
        
        // Random dimensions and speed
        const size = Math.random() * 4 + 2;
        const left = Math.random() * 100;
        const duration = Math.random() * 8 + 4;
        const delay = Math.random() * 8;
        
        flake.style.width = `${size}px`;
        flake.style.height = `${size}px`;
        flake.style.left = `${left}%`;
        flake.style.animationDuration = `${duration}s`;
        flake.style.animationDelay = `-${delay}s`;
        
        snowOverlay.appendChild(flake);
      }
    }
  </script>
