---
import Layout from '../layouts/Layout.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import StepsForm from '../components/StepsForm.astro';
import communes from '../data/communes.json';

const title = "Toiture & Charpente en Isère (38) | Devis Gratuits alpins 2026";
const description = "Rénovation de toiture en montagne, pose d'ardoise et lauze dauphinoise, renforcement de charpente charge neige C2. Obtenez 3 devis d'artisans RGE en Isère.";

// Select the top 12 cities for homepage list
const popularCities = communes.slice(0, 12);
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    faqItems={[
      {
        q: "Quel est le coût d'un couvreur en Isère en 2026 ?",
        a: "Le tarif d'un couvreur en Isère varie selon le projet : entre 90€ et 145€ le m² TTC pour des tuiles résistantes au gel, et de 130€ à 200€ le m² TTC pour de l'ardoise naturelle, pose et dépose comprises. Les projets de lauze montagnarde oscillent entre 200€ et 350€ le m²."
      },
      {
        q: "Quelles sont les obligations de charge neige en zone C2 en Isère ?",
        a: "Pour l'Isère, les communes au-dessus de 500m d'altitude font face à la zone de neige C2. Les charpentes doivent supporter une surcharge allant jusqu'à 200 kg/m² et intégrer des crochets arrêts de neige (crochets anti-avalanche) pour éviter les glissements brutaux."
      },
      {
        q: "Comment financer l'isolation de sa toiture en montagne ?",
        a: "En confiant vos travaux d'isolation (sarking ou combles) à un artisan certifié RGE en Isère, vous pouvez obtenir les subventions MaPrimeRénov' (ANAH), les primes CEE de l'Isère et bénéficier d'une TVA réduite à 5,5%."
      }
    ]}
  />

  <!-- Hero Section -->
  <section class="hero">
    <!-- Suble Snow Particles Animation Container -->
    <div class="snow-container" id="snow-overlay"></div>
    <div class="container" style="position: relative; z-index: 2;">
      <div class="two-column-layout">
        <!-- Hero Left Info -->
        <div>
          <div class="alert-pill">
            <div class="alert-pulse-icon"></div>
            <span>Expert toiture montagne — normes neige C2</span>
          </div>
          <h1>
            Votre Toiture Alpine Solide &amp; Résistante en Isère (38)
          </h1>
          <p>
            Cycles intenses de gel-dégel, surcharges de neige lourde en altitude et orages de grêle en plaine... Votre couverture dauphinoise subit un climat rigoureux. Comparez 3 couvreurs alpins certifiés RGE assurés en décennale.
          </p>
          
          <div style="display: flex; gap: 20px; margin-top: 10px; flex-wrap: wrap;">
            <div style="background: rgba(255, 255, 255, 0.08); border: 1.5px solid rgba(255, 255, 255, 0.15); padding: 12px 20px; border-radius: var(--radius-sm);">
              <span style="font-size: 20px; margin-right: 8px;">🛡️</span>
              <strong style="color: white; font-size: 14.5px;">Garantie Décennale 10 ans</strong>
            </div>
            <div style="background: rgba(255, 255, 255, 0.08); border: 1.5px solid rgba(255, 255, 255, 0.15); padding: 12px 20px; border-radius: var(--radius-sm);">
              <span style="font-size: 20px; margin-right: 8px;">❄️</span>
              <strong style="color: white; font-size: 14.5px;">Normes Altitude &amp; Antigel</strong>
            </div>
          </div>
        </div>

        <!-- Hero Right Form -->
        <div>
          <StepsForm />
        </div>
      </div>
    </div>
  </section>

  <!-- Regional Context Section -->
  <section style="padding: 75px 0; background-color: var(--card-bg);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <span class="badge-pill" style="margin-bottom: 15px;">⛰️ Faire Face au Climat Alpin</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 900; color: var(--primary); margin-bottom: 15px;">
          Pourquoi les toitures en Isère exigent une technicité spécifique ?
        </h2>
        <p style="font-size: 16.5px; color: var(--text-muted); line-height: 1.6;">
          Le département de l'Isère (38) associe des zones de plaines et de piémonts exposées aux orages à des massifs montagneux (Chartreuse, Vercors, Oisans) soumis au gel et à la neige.
        </p>
      </div>

      <div class="two-column-layout" style="align-items: stretch; gap: 40px;">
        <!-- Left: Weather challenges cards -->
        <div style="display: flex; flex-direction: column; gap: 20px;">
          <div class="card" style="border-left: 4px solid var(--secondary); border-top: none; display: flex; gap: 15px; padding: 20px; align-items: start;">
            <div style="font-size: 28px; line-height: 1;">❄️</div>
            <div>
              <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin-bottom: 6px;">Surcharge de Neige Zone C2</h3>
              <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.5; margin: 0;">
                En altitude, le poids de la neige lourde peut atteindre 200 kg/m². Les charpentes doivent être renforcées (Eurocode 5) et équipées de crochets arrêts de neige (anti-avalanche).
              </p>
            </div>
          </div>

          <div class="card" style="border-left: 4px solid var(--secondary); border-top: none; display: flex; gap: 15px; padding: 20px; align-items: start;">
            <div style="font-size: 28px; line-height: 1;">🥶</div>
            <div>
              <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin-bottom: 6px;">Cycles de Gel-Dégel Alpins</h3>
              <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.5; margin: 0;">
                Avec 80 à 120 jours de gel par an, l'eau s'infiltre et fait éclater les tuiles ordinaires. L'ardoise naturelle et les tuiles terre cuite antigel sont obligatoires en montagne.
              </p>
            </div>
          </div>

          <div class="card" style="border-left: 4px solid var(--secondary); border-top: none; display: flex; gap: 15px; padding: 20px; align-items: start;">
            <div style="font-size: 28px; line-height: 1;">🪵</div>
            <div>
              <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin-bottom: 6px;">Charpentes Dauphinoises à Forte Pente</h3>
              <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.5; margin: 0;">
                Les habitations de plaine ou de piémont présentent souvent des pentes supérieures à 45° couvertes de tuiles écaille pour protéger les murs en pisé traditionnels.
              </p>
            </div>
          </div>
        </div>

        <!-- Right: Illustrative image -->
        <div style="border-radius: var(--radius-md); overflow: hidden; border: 2px solid var(--border-color); box-shadow: var(--shadow-sm); display: flex; flex-direction: column;">
          <img 
            src="/images/hero-toiture-isere.png" 
            alt="Chalet dauphinois avec toiture en ardoise naturelle sous un ciel alpin en Isère" 
            style="width: 100%; height: 100%; object-fit: cover; min-height: 350px;" 
          />
          <div style="padding: 12px 18px; background: white; border-top: 1.5px solid var(--border-color); font-size: 12.5px; color: var(--text-muted); font-family: var(--font-mono);">
            🏡 Chalet dauphinois : toiture d'ardoise naturelle et charpente renforcée montagne.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Materials Guide Section (Altitude based) -->
  <section style="padding: 75px 0; background-color: #F0FDF4; border-top: 1.5px solid var(--border-color); border-bottom: 1.5px solid var(--border-color);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <span class="badge-pill" style="margin-bottom: 15px;">🏔️ Guide d'Altitude</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 900; color: var(--primary); margin-bottom: 15px;">
          Quels matériaux choisir selon l'altitude de mon habitation ?
        </h2>
        <p style="font-size: 16px; color: var(--text-muted);">
          Les prescriptions techniques varient fortement selon les zones géographiques de l'Isère.
        </p>
      </div>

      <div class="grid-3" style="align-items: stretch;">
        <!-- Plaine -->
        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); padding: 30px; display: flex; flex-direction: column;">
          <div style="font-size: 36px; margin-bottom: 15px;">🏡</div>
          <h3 style="font-family: var(--font-heading); font-size: 19px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">Plaine &amp; Bas-Dauphiné (&lt; 500m)</h3>
          <p style="font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 20px; flex-grow: 1;">
            Pour les maisons en plaine à Bourgoin-Jallieu ou Vienne. Les tuiles mécaniques romanes double emboîtement ou les tuiles plates écaille traditionnelles pour maisons en pisé.
          </p>
          <ul style="padding-left: 20px; font-size: 13px; color: var(--text); display: flex; flex-direction: column; gap: 8px; margin: 0;">
            <li><strong>Type :</strong> Tuile terre cuite écaille ou romane</li>
            <li><strong>Pente :</strong> 25% à 45%+ (dauphinoise)</li>
            <li><strong>Priorité :</strong> Étanchéité orages et grêle</li>
          </ul>
        </div>

        <!-- Moyenne Montagne -->
        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); padding: 30px; display: flex; flex-direction: column;">
          <div style="font-size: 36px; margin-bottom: 15px;">🏔️</div>
          <h3 style="font-family: var(--font-heading); font-size: 19px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">Moyenne Montagne (500m – 1000m)</h3>
          <p style="font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 20px; flex-grow: 1;">
            Pour les massifs de Chartreuse et du Vercors (Villard-de-Lans). Tuiles terre cuite haut de gamme certifiées antigel (classe 1) ou ardoise naturelle posée au crochet inox.
          </p>
          <ul style="padding-left: 20px; font-size: 13px; color: var(--text); display: flex; flex-direction: column; gap: 8px; margin: 0;">
            <li><strong>Type :</strong> Tuile antigel ou ardoise naturelle</li>
            <li><strong>Pente :</strong> Forte pente (&gt; 40°)</li>
            <li><strong>Priorité :</strong> Crochets d'arrêt de neige</li>
          </ul>
        </div>

        <!-- Haute Altitude -->
        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--shadow-sm); padding: 30px; display: flex; flex-direction: column;">
          <div style="font-size: 36px; margin-bottom: 15px;">❄️</div>
          <h3 style="font-family: var(--font-heading); font-size: 19px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">Haute Altitude (1000m+)</h3>
          <p style="font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 20px; flex-grow: 1;">
            Pour les stations d'Oisans et Belledonne. Ardoise naturelle d'épaisseur renforcée ou lauze calcaire montagnarde posée sur isolation extérieure sarking continue.
          </p>
          <ul style="padding-left: 20px; font-size: 13px; color: var(--text); display: flex; flex-direction: column; gap: 8px; margin: 0;">
            <li><strong>Type :</strong> Ardoise épaisse ou lauze traditionnelle</li>
            <li><strong>Pente :</strong> Trés forte pente (&gt; 45°)</li>
            <li><strong>Priorité :</strong> Isolation sarking + Eurocode 5</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Interactive Snow Load Simulator Section -->
  <section style="padding: 75px 0; background-color: var(--card-bg);">
    <div class="container" style="max-width: 800px;">
      <div style="text-align: center; margin-bottom: 40px;">
        <span class="badge-pill" style="margin-bottom: 15px;">❄️ Simulateur Charge Neige Isère</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 900; color: var(--primary); margin-bottom: 15px;">
          Calculer la capacité de charge requise pour mon toit
        </h2>
        <p style="font-size: 16px; color: var(--text-muted);">
          Estimez la résistance nécessaire de votre toiture selon les critères d'altitude et de pente de votre projet en Isère (normes C2).
        </p>
      </div>

      <div style="background: white; border: 2px solid var(--border-color); border-radius: var(--radius-md); padding: 35px; box-shadow: var(--shadow-alpine);">
        <div style="display: flex; flex-direction: column; gap: 20px;">
          <!-- Field 1: Altitude range -->
          <div class="form-group">
            <label style="font-family: var(--font-heading); font-weight: bold; font-size: 15.5px;">Altitude de la maison (m) :</label>
            <div style="display: flex; justify-content: space-between; font-weight: bold; margin-bottom: 8px;">
              <span id="simulator-alt-val" style="color: var(--secondary); font-family: var(--font-mono);">500 m</span>
            </div>
            <input type="range" id="simulator-alt" min="100" max="2000" step="50" value="500" style="width: 100%; accent-color: var(--secondary); cursor: pointer;" />
          </div>

          <!-- Field 2: Roof Slope -->
          <div class="form-group">
            <label style="font-family: var(--font-heading); font-weight: bold; font-size: 15.5px;">Pente du toit (degrés) :</label>
            <div style="display: flex; justify-content: space-between; font-weight: bold; margin-bottom: 8px;">
              <span id="simulator-slope-val" style="color: var(--secondary); font-family: var(--font-mono);">30 °</span>
            </div>
            <input type="range" id="simulator-slope" min="15" max="60" step="5" value="30" style="width: 100%; accent-color: var(--secondary); cursor: pointer;" />
          </div>

          <!-- Field 3: Roof Orientation -->
          <div class="form-group">
            <label style="font-family: var(--font-heading); font-weight: bold; font-size: 15.5px;">Exposition au vent / Orientation :</label>
            <div style="display: flex; gap: 15px; margin-top: 5px;">
              <label style="font-size: 14.5px; display: flex; align-items: center; gap: 8px; cursor: pointer;">
                <input type="radio" name="simulator-wind" value="1" checked style="accent-color: var(--primary);" /> Abrité (stagnation neige)
              </label>
              <label style="font-size: 14.5px; display: flex; align-items: center; gap: 8px; cursor: pointer;">
                <input type="radio" name="simulator-wind" value="0.8" style="accent-color: var(--primary);" /> Exposé (neige balayée par le vent)
              </label>
            </div>
          </div>

          <!-- Divider -->
          <hr style="border: 0; border-top: 1.5px solid var(--border-color); margin: 10px 0;" />

          <!-- Output Box -->
          <div style="background: var(--primary-light); border: 2.5px dashed var(--border-color); padding: 25px; border-radius: var(--radius-sm); display: flex; flex-direction: column; align-items: center; gap: 10px;">
            <div style="font-size: 13.5px; color: var(--primary); font-weight: bold; text-transform: uppercase; letter-spacing: 0.5px;">Résistance de charge neige estimée :</div>
            <div style="font-size: 32px; font-weight: 900; color: var(--primary); font-family: var(--font-mono);" id="simulator-result">
              120 kg/m²
            </div>
            <p style="font-size: 12.5px; color: var(--text-muted); text-align: center; margin: 0;" id="simulator-advice">
              Norme neige standard. Les crochets arrêts de neige sont recommandés.
            </p>
          </div>

          <div style="text-align: center; margin-top: 10px;">
            <a href="#devis" class="btn-primary" style="display: inline-block;">📋 Demander un Devis Charpente Renforcée &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Work Seasonality Section -->
  <section style="padding: 75px 0; background-color: #F8FAFC; border-top: 1.5px solid var(--border-color); border-bottom: 1.5px solid var(--border-color);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <span class="badge-pill" style="margin-bottom: 15px;">📅 Saisonnalité Chantier</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 900; color: var(--primary); margin-bottom: 15px;">
          Calendrier d'intervention optimal en Isère
        </h2>
        <p style="font-size: 16px; color: var(--text-muted);">
          En raison des contraintes climatiques alpines, la planification de travaux de toiture dépend étroitement de l'altitude.
        </p>
      </div>

      <div class="two-column-layout" style="gap: 40px; align-items: center;">
        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 30px; box-shadow: var(--shadow-sm);">
          <h3 style="font-family: var(--font-heading); font-size: 19px; font-weight: 800; color: var(--primary); margin-bottom: 20px;">En Altitude (Massifs &amp; Montagne)</h3>
          <div style="display: flex; flex-direction: column; gap: 15px; font-size: 14.5px;">
            <div style="display: flex; gap: 15px;">
              <span style="font-size: 20px; font-family: var(--font-mono); color: #dc2626; font-weight: bold; width: 80px; flex-shrink: 0;">NOV-AVR :</span>
              <span style="color: var(--text-muted);">❄️ <strong>Saison morte.</strong> Tempêtes de neige, toits glissants et gel persistant rendent les interventions impossibles (sauf urgence).</span>
            </div>
            <div style="display: flex; gap: 15px; border-top: 1px solid var(--border-color); padding-top: 15px;">
              <span style="font-size: 20px; font-family: var(--font-mono); color: #ea580c; font-weight: bold; width: 80px; flex-shrink: 0;">MAI-JUIN :</span>
              <span style="color: var(--text-muted);">🌱 <strong>Démarrage.</strong> Période idéale pour le nettoyage de toiture après la fonte et le diagnostic des dégâts du gel.</span>
            </div>
            <div style="display: flex; gap: 15px; border-top: 1px solid var(--border-color); padding-top: 15px;">
              <span style="font-size: 20px; font-family: var(--font-mono); color: #16a34a; font-weight: bold; width: 80px; flex-shrink: 0;">JUIL-OCT :</span>
              <span style="color: var(--text-muted);">☀️ <strong>Saison haute.</strong> Travaux de réfection complète, isolation sarking et renfort de charpentes avant le retour des neiges.</span>
            </div>
          </div>
        </div>

        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 30px; box-shadow: var(--shadow-sm);">
          <h3 style="font-family: var(--font-heading); font-size: 19px; font-weight: 800; color: var(--primary); margin-bottom: 20px;">En Plaine &amp; Cuvette Grenobloise</h3>
          <div style="display: flex; flex-direction: column; gap: 15px; font-size: 14.5px;">
            <div style="display: flex; gap: 15px;">
              <span style="font-size: 20px; font-family: var(--font-mono); color: #ea580c; font-weight: bold; width: 80px; flex-shrink: 0;">DEC-FEB :</span>
              <span style="color: var(--text-muted);">🥶 <strong>Ralenti.</strong> Interventions possibles sur les toitures selon les fenêtres météo, mais limitées par les gelées matinales et le verglas.</span>
            </div>
            <div style="display: flex; gap: 15px; border-top: 1px solid var(--border-color); padding-top: 15px;">
              <span style="font-size: 20px; font-family: var(--font-mono); color: #16a34a; font-weight: bold; width: 80px; flex-shrink: 0;">MAR-OCT :</span>
              <span style="color: var(--text-muted);">☀️ <strong>Période idéale.</strong> Tous travaux de couverture et démoussage. Attention toutefois aux orages de grêle violents en fin d'été.</span>
            </div>
            <div style="display: flex; gap: 15px; border-top: 1px solid var(--border-color); padding-top: 15px;">
              <span style="font-size: 20px; font-family: var(--font-mono); color: #ea580c; font-weight: bold; width: 80px; flex-shrink: 0;">NOV :</span>
              <span style="color: var(--text-muted);">🍂 <strong>Nettoyage d'automne.</strong> Période recommandée pour le nettoyage des cheneaux obstrués par les feuilles avant le gel hivernal.</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Popular Cities Link Directory -->
  <section style="padding: 75px 0; background-color: var(--bg); border-top: 1.5px solid var(--border-color);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 40px;">
        <span class="badge-pill" style="margin-bottom: 15px;">🗺️ Interventions locales</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 900; color: var(--primary);">
          Villes principales d'intervention en Isère
        </h2>
        <p style="font-size: 16px; color: var(--text-muted); margin-top: 10px;">
          Retrouvez nos couvreurs partenaires actifs sur votre secteur géographique du 38.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(260px, 1fr)); gap: 20px;">
        {popularCities.map((c) => (
          <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 20px; box-shadow: var(--shadow-sm); display: flex; flex-direction: column; justify-content: space-between;">
            <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 800; color: var(--text); margin-bottom: 12px;">
              🏢 Couvreur {c.nom} ({c.codePostal})
            </h3>
            <div style="display: flex; flex-direction: column; gap: 6px; font-size: 13px;">
              <a href={`/toiture-charpente-${c.slug}/`} style="color: var(--secondary); font-weight: bold;">🔨 Toiture &amp; Couverture &rarr;</a>
              <a href={`/entretien-toiture-${c.slug}/`} style="color: var(--secondary); font-weight: bold;">🧼 Nettoyage &amp; Démoussage &rarr;</a>
              <a href={`/couvreur-montagne-${c.slug}/`} style="color: var(--secondary); font-weight: bold;">👤 Couvreur Certifié RGE &rarr;</a>
            </div>
          </div>
        ))}
      </div>
      
      <div style="text-align: center; margin-top: 40px;">
        <a href="/communes/" class="btn-secondary" style="display: inline-block;">🗺️ Voir toutes les communes de l'Isère &rarr;</a>
      </div>
    </div>
  </section>

  <!-- GUIDES — Internal Linking -->
  <section style="padding: 75px 0; background-color: var(--card-bg); border-top: 1.5px solid var(--border-color);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 40px;">
        <span class="badge-pill" style="margin-bottom: 15px;">📚 Nos Guides Experts</span>
        <h2 style="font-family: var(--font-heading); font-size: 32px; font-weight: 900; color: var(--primary);">
          Tout savoir sur la toiture de montagne en Isère
        </h2>
