---
import Layout from '../layouts/Layout.astro';
import SchemaMarkup from '../components/SchemaMarkup.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import StepsForm from '../components/StepsForm.astro';
import communes from '../data/communes.json';
import { generateCommuneContent, getDynamicPrices } from '../lib/contentEngine';
import { getSmartNearbyCommunes } from '../lib/geoLinks';

export async function getStaticPaths() {
  return communes.map((c) => ({
    params: { commune: c.slug },
    props: { commune: c },
  }));
}

const { commune } = Astro.props;
const pageType = 'refection';
const local = generateCommuneContent(commune, pageType);
const prices = getDynamicPrices(commune);
const nearby = getSmartNearbyCommunes(commune.slug, communes, 6, 2);

const title = local.title;
const description = local.introParagraph.substring(0, 160);

const breadcrumbItems = [
  { label: "Accueil", href: "/" },
  { label: "Villes Isère (38)", href: "/communes/" },
  { label: `Toiture & Charpente à ${commune.nom}` }
];
---

<Layout title={title} description={description}>
  <SchemaMarkup
    slot="head"
    pageUrl={Astro.url.href}
    pageTitle={title}
    pageDescription={description}
    faqItems={local.faqItems}
    breadcrumbItems={[
      { label: "Accueil", href: "/" },
      { label: "Villes Isère", href: "/communes/" },
      { label: `Toiture & Charpente à ${commune.nom}` }
    ]}
    communeName={commune.nom}
    communeData={commune}
  />

  <Breadcrumb items={breadcrumbItems} />

  <!-- ═══ HERO SECTION ═══ -->
  <section style="background: linear-gradient(135deg, rgba(20,83,45,0.07) 0%, rgba(3,105,161,0.04) 100%); padding: 55px 0; border-bottom: 2px solid var(--border-color); position: relative;">
    <div class="container">
      <div class="two-column-layout">
        <div style="display: flex; flex-direction: column; justify-content: center;">
          <div class="badge-pill" style="width: max-content; margin-bottom: 18px;">
            🛡️ Couverture & Rénovation — {commune.nom} ({commune.codePostal})
          </div>
          <h1 style="font-family: var(--font-heading); font-size: 36px; font-weight: 900; color: var(--primary); line-height: 1.25; margin-bottom: 18px;">
            Toiture &amp; Charpente à <span style="color: var(--secondary);">{commune.nom}</span> ({commune.codePostal})
          </h1>
          <p style="font-size: 16.5px; line-height: 1.75; color: var(--text); margin-bottom: 22px;">
            {local.introParagraph}
          </p>

          <!-- Tuile dominante / Fixation technique -->
          {local.roofCharacteristics && (
            <div style="background: white; border: 1.5px solid var(--border-color); border-left: 4px solid var(--secondary); padding: 16px 20px; border-radius: var(--radius-sm); margin-bottom: 22px;">
              <div style="font-weight: 800; color: var(--secondary); font-size: 13px; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 10px;">📐 Données Techniques — Toitures à {commune.nom}</div>
              <ul style="list-style: none; padding: 0; margin: 0; font-size: 13.5px; color: var(--text-muted); line-height: 1.8;">
                {local.roofCharacteristics.tuileDominante && <li>🪨 <strong>Couverture principale :</strong> {local.roofCharacteristics.tuileDominante}</li>}
                {local.roofCharacteristics.fixation && <li>🔩 <strong>Fixation préconisée :</strong> {local.roofCharacteristics.fixation}</li>}
                {local.roofCharacteristics.ventilation && <li>💨 <strong>Ventilation requise :</strong> {local.roofCharacteristics.ventilation}</li>}
                {local.roofCharacteristics.ecran && <li>🛡️ <strong>Écran recommandé :</strong> {local.roofCharacteristics.ecran}</li>}
              </ul>
            </div>
          )}

          <!-- Conseil local -->
          {local.conseilLocal && (
            <div style="background: #F0FDF4; border: 1.5px solid var(--border-color); border-left: 4px solid var(--primary); padding: 16px 20px; border-radius: var(--radius-sm); margin-bottom: 22px;">
              <div style="font-weight: 800; color: var(--primary); margin-bottom: 6px; font-size: 14px;">💡 Conseil Pratique à {commune.nom} :</div>
              <p style="font-size: 13.5px; color: var(--text-muted); margin: 0; line-height: 1.6;">{local.conseilLocal}</p>
            </div>
          )}

          <!-- Stats rapides -->
          <div style="display: flex; gap: 15px; flex-wrap: wrap;">
            <div style="background: white; border: 1.5px solid var(--border-color); padding: 12px 18px; border-radius: var(--radius-sm); text-align: center; flex: 1; min-width: 100px;">
              <div style="font-size: 20px; font-weight: 900; color: var(--primary);">{commune.marketData?.couvreursRGE || 3}</div>
              <div style="font-size: 11px; color: var(--text-muted); font-weight: 700;">Couvreurs RGE</div>
            </div>
            <div style="background: white; border: 1.5px solid var(--border-color); padding: 12px 18px; border-radius: var(--radius-sm); text-align: center; flex: 1; min-width: 100px;">
              <div style="font-size: 20px; font-weight: 900; color: var(--primary);">{prices.refectionRomane.min}€</div>
              <div style="font-size: 11px; color: var(--text-muted); font-weight: 700;">Dès /m² TTC</div>
            </div>
            <div style="background: white; border: 1.5px solid var(--border-color); padding: 12px 18px; border-radius: var(--radius-sm); text-align: center; flex: 1; min-width: 100px;">
              <div style="font-size: 20px; font-weight: 900; color: var(--primary);">{commune.marketData?.delaiMoyenJours || 10}j</div>
              <div style="font-size: 11px; color: var(--text-muted); font-weight: 700;">Délai devis</div>
            </div>
          </div>
        </div>

        <!-- Hero Form -->
        <div>
          <StepsForm initialZip={commune.codePostal} initialCommune={commune.nom} />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SPÉCIFICITÉS LOCALES ═══ -->
  <section style="padding: 70px 0; background-color: var(--card-bg);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <h2 style="font-family: var(--font-heading); font-size: 30px; font-weight: 900; color: var(--primary); margin-bottom: 14px;">
          Spécificités techniques de la couverture à {commune.nom}
        </h2>
        <p style="font-size: 15.5px; color: var(--text-muted);">
          Climat, patrimoine et réglementation locale : ce que tout couvreur du 38 doit maîtriser à {commune.nom}.
        </p>
      </div>

      <div class="grid-3">
        <div class="card">
          <div style="font-size: 28px; margin-bottom: 12px;">❄️</div>
          <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">Climat &amp; Contraintes Neige</h3>
          <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.7; margin: 0;">
            {local.climateContext}
          </p>
        </div>

        <div class="card">
          <div style="font-size: 28px; margin-bottom: 12px;">🏛️</div>
          <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">PLU &amp; Réglementation ABF</h3>
          <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.7; margin: 0;">
            {local.abfRegulations}
          </p>
        </div>

        <div class="card">
          <div style="font-size: 28px; margin-bottom: 12px;">🏡</div>
          <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">Typologie du Bâti Local</h3>
          <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.7; margin: 0;">
            {local.housingTypologyInsight}
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ RÉGLEMENTATION ═══ -->
  <section style="padding: 70px 0; background: linear-gradient(180deg, #F0FDF4 0%, #fff 100%); border-top: 1.5px solid var(--border-color);">
    <div class="container" style="max-width: 950px;">
      <div style="text-align: center; margin-bottom: 45px;">
        <h2 style="font-family: var(--font-heading); font-size: 30px; font-weight: 900; color: var(--primary); margin-bottom: 14px;">
          Réglementation Toiture à {commune.nom} (38)
        </h2>
        <p style="font-size: 15.5px; color: var(--text-muted);">
          Ce qu'il faut absolument savoir avant de lancer vos travaux de couverture.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 22px;">
        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 28px; box-shadow: var(--shadow-sm);">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 14px;">
            <span style="font-size: 26px;">📋</span>
            <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin: 0;">PLU &amp; Autorisations</h3>
          </div>
          <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.75; margin: 0;">{local.regulations.plu}</p>
        </div>

        <div style="background: white; border: 1.5px solid #bbf7d0; border-radius: var(--radius-md); padding: 28px; box-shadow: var(--shadow-sm);">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 14px;">
            <span style="font-size: 26px;">❄️</span>
            <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin: 0;">Normes Charge Neige</h3>
          </div>
          <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.75; margin: 0;">{local.regulations.risqueIncendie}</p>
        </div>

        <div style="background: white; border: 1.5px solid #bfdbfe; border-radius: var(--radius-md); padding: 28px; box-shadow: var(--shadow-sm);">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 14px;">
            <span style="font-size: 26px;">⛰️</span>
            <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin: 0;">Sécurité &amp; Glissement de Neige</h3>
          </div>
          <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.75; margin: 0;">{local.regulations.mistral}</p>
        </div>

        <div style="background: white; border: 1.5px solid #f3e8ff; border-radius: var(--radius-md); padding: 28px; box-shadow: var(--shadow-sm);">
          <div style="display: flex; align-items: center; gap: 12px; margin-bottom: 14px;">
            <span style="font-size: 26px;">🏛️</span>
            <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin: 0;">Validation ABF</h3>
          </div>
          <p style="font-size: 13.5px; color: var(--text-muted); line-height: 1.75; margin: 0;">{local.regulations.abf}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TARIFS ═══ -->
  <section style="padding: 70px 0; background-color: var(--card-bg);">
    <div class="container">
      <div style="text-align: center; max-width: 800px; margin: 0 auto 50px;">
        <h2 style="font-family: var(--font-heading); font-size: 30px; font-weight: 900; color: var(--primary); margin-bottom: 14px;">
          Tarifs des Couvreurs à {commune.nom} en 2026
        </h2>
        <p style="font-size: 15.5px; color: var(--text-muted);">
          Indicateurs de prix moyens constatés en Isère (38) pour des travaux de couverture en 2026. Tarifs TTC, main d'œuvre et matériaux inclus.
        </p>
      </div>

      <div style="max-width: 880px; margin: 0 auto; overflow-x: auto; background: white; border: 2px solid var(--border-color); border-radius: var(--radius-md); box-shadow: var(--shadow-sm);">
        <table style="width: 100%; border-collapse: collapse; text-align: left; font-size: 14.5px;">
          <thead>
            <tr style="background: var(--primary); color: white;">
              <th style="padding: 16px 20px; font-family: var(--font-heading); font-weight: 800;">Type de Travaux</th>
              <th style="padding: 16px 20px; font-family: var(--font-heading); font-weight: 800;">Fourchette Prix 2026</th>
              <th style="padding: 16px 20px; font-family: var(--font-heading); font-weight: 800;">Unité</th>
            </tr>
          </thead>
          <tbody>
            <tr style="border-bottom: 1px solid var(--border-color);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Réfection ardoise naturelle (crochets inox)</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.refectionArdoise.min} – {prices.refectionArdoise.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">au m² (pose comprise)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color); background: var(--primary-light);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Réfection tuiles romanes / béton (certifiées antigel)</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.refectionRomane.min} – {prices.refectionRomane.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">au m² (pose comprise)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Restauration toiture en lauze calcaire</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.refectionLauze.min} – {prices.refectionLauze.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">au m² (pose comprise)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color); background: var(--primary-light);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Démoussage + Traitement Hydrofuge antigel</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.demoussageHydro.min} – {prices.demoussageHydro.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">au m² (effet perlant 10 ans)</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Arrêts de neige (crochets anti-avalanche)</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.crochetNeigeMl.min} – {prices.crochetNeigeMl.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">au mètre linéaire</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color); background: var(--primary-light);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Zinguerie Zinc (descentes calibre neige)</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.zinguerieMl.min} – {prices.zinguerieMl.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">au mètre linéaire</td>
            </tr>
            <tr style="border-bottom: 1px solid var(--border-color);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Charpente renforcée montagne (Eurocode 5)</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.charpenteMontagne.min} – {prices.charpenteMontagne.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">au m² (bois de pays C24)</td>
            </tr>
            <tr style="background: var(--primary-light);">
              <td style="padding: 15px 20px; font-weight: bold; color: var(--primary);">Isolation Sarking continue (fibre de bois R=5+)</td>
              <td style="padding: 15px 20px;"><span class="price-tag">{prices.isolationSarking.min} – {prices.isolationSarking.max} €</span></td>
              <td style="padding: 15px 20px; color: var(--text-muted);">au m² (éligible aides RGE)</td>
            </tr>
          </tbody>
        </table>
      </div>
      <p style="text-align: center; font-size: 12.5px; color: var(--text-muted); margin-top: 16px;">
        ⚠️ Tarifs indicatifs TTC 2026 pour le département de l'Isère (38). Le devis personnalisé reste le seul document contractuel.
      </p>
      <div style="text-align: center; margin-top: 25px;">
        <a href="#devis" class="btn-primary" style="display: inline-block;">📋 Recevoir une estimation gratuite pour {commune.nom} →</a>
      </div>
    </div>
  </section>

  <!-- ═══ AIDES & SUBVENTIONS ═══ -->
  <section style="padding: 70px 0; background: linear-gradient(180deg, #F0FDF4 0%, #fff 100%); border-top: 1.5px solid var(--border-color);">
    <div class="container" style="max-width: 950px;">
      <div style="text-align: center; margin-bottom: 45px;">
        <h2 style="font-family: var(--font-heading); font-size: 30px; font-weight: 900; color: var(--primary); margin-bottom: 14px;">
          Aides &amp; Subventions Toiture à {commune.nom} (2026)
        </h2>
        <p style="font-size: 15.5px; color: var(--text-muted);">
          Cumulez les dispositifs d'aides pour réduire votre reste-à-charge sur vos isolations thermiques.
        </p>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 30px;">
        <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 24px; box-shadow: var(--shadow-sm);">
          <div style="font-size: 24px; margin-bottom: 10px;">🏛️</div>
          <h3 style="font-family: var(--font-heading); font-size: 16px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">MaPrimeRénov' 2026</h3>
          <p style="font-size: 13px; color: var(--text-muted); line-height: 1.7; margin: 0;">{local.aides.maprime}</p>
        </div>

        <div style="background: white; border: 1.5px solid #dbeafe; border-radius: var(--radius-md); padding: 24px; box-shadow: var(--shadow-sm);">
          <div style="font-size: 24px; margin-bottom: 10px;">⚡</div>
          <h3 style="font-family: var(--font-heading); font-size: 16px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">Primes CEE de l'Isère</h3>
          <p style="font-size: 13px; color: var(--text-muted); line-height: 1.7; margin: 0;">{local.aides.cee}</p>
        </div>

        <div style="background: white; border: 1.5px solid #bbf7d0; border-radius: var(--radius-md); padding: 24px; box-shadow: var(--shadow-sm);">
          <div style="font-size: 24px; margin-bottom: 10px;">📉</div>
          <h3 style="font-family: var(--font-heading); font-size: 16px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">TVA réduite à 5,5%</h3>
          <p style="font-size: 13px; color: var(--text-muted); line-height: 1.7; margin: 0;">{local.aides.tva}</p>
        </div>

        <div style="background: white; border: 1.5px solid #f3e8ff; border-radius: var(--radius-md); padding: 24px; box-shadow: var(--shadow-sm);">
          <div style="font-size: 24px; margin-bottom: 10px;">🏠</div>
          <h3 style="font-family: var(--font-heading); font-size: 16px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">Aides de l'ANAH</h3>
          <p style="font-size: 13px; color: var(--text-muted); line-height: 1.7; margin: 0;">{local.aides.anah}</p>
        </div>
      </div>

      <div style="background: linear-gradient(135deg, var(--primary), #1e3a8a); color: white; border-radius: var(--radius-md); padding: 28px; text-align: center;">
        <div style="font-size: 28px; margin-bottom: 12px;">💰</div>
        <h3 style="font-family: var(--font-heading); font-size: 19px; font-weight: 800; margin-bottom: 12px;">Cumul des subventions à {commune.nom} :</h3>
        <p style="font-size: 14.5px; line-height: 1.7; opacity: 0.92; margin-bottom: 18px;">{local.aides.total}</p>
        <a href="#devis" style="background: white; color: var(--primary); font-family: var(--font-heading); font-weight: 800; padding: 12px 28px; border-radius: 30px; font-size: 14px; text-decoration: none; display: inline-block;">
          Vérifier mon éligibilité →
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ PERFORMANCE ÉNERGÉTIQUE ═══ -->
  <section style="padding: 70px 0; background-color: var(--card-bg); border-top: 1.5px solid var(--border-color);">
    <div class="container" style="max-width: 900px;">
      <div style="text-align: center; margin-bottom: 40px;">
        <h2 style="font-family: var(--font-heading); font-size: 30px; font-weight: 900; color: var(--primary); margin-bottom: 14px;">
          Isolation &amp; Valorisation Immobilière à {commune.nom}
        </h2>
      </div>

      <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-md); padding: 32px; box-shadow: var(--shadow-sm); margin-bottom: 24px;">
        <div style="display: flex; align-items: flex-start; gap: 16px; margin-bottom: 28px;">
          <span style="font-size: 36px; flex-shrink: 0;">🔥</span>
          <div>
            <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">Économies d'Énergie &amp; Déphasage Confort d'Été</h3>
            <p style="font-size: 14.5px; color: var(--text-muted); line-height: 1.75; margin: 0;">{local.energyProfileText}</p>
          </div>
        </div>
        <hr style="border: 0; border-top: 1px solid var(--border-color); margin-bottom: 28px;" />
        <div style="display: flex; align-items: flex-start; gap: 16px;">
          <span style="font-size: 36px; flex-shrink: 0;">📈</span>
          <div>
            <h3 style="font-family: var(--font-heading); font-size: 18px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">Valorisation de Votre Bien à {commune.nom}</h3>
            <p style="font-size: 14.5px; color: var(--text-muted); line-height: 1.75; margin: 0;">{local.realEstateInsight}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section style="padding: 70px 0; background-color: var(--bg); border-top: 1.5px solid var(--border-color);">
    <div class="container" style="max-width: 860px;">
      <div style="text-align: center; margin-bottom: 45px;">
        <h2 style="font-family: var(--font-heading); font-size: 30px; font-weight: 900; color: var(--primary); margin-bottom: 10px;">
          Questions Fréquentes — Couverture &amp; Toiture à {commune.nom}
        </h2>
        <p style="font-size: 15.5px; color: var(--text-muted);">
          Réponses aux questions pratiques que se posent les propriétaires du {commune.codePostal}.
        </p>
      </div>

      <div style="display: flex; flex-direction: column; gap: 16px;">
        {local.faqItems.map((item) => (
          <div style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 24px; box-shadow: var(--shadow-sm);">
            <h3 style="font-family: var(--font-heading); font-size: 17px; font-weight: 800; color: var(--primary); margin-bottom: 10px; display: flex; align-items: flex-start; gap: 10px;">
              <span style="background: var(--primary); color: white; width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 12px; flex-shrink: 0; margin-top: 1px;">Q</span>
              {item.q}
            </h3>
            <p style="font-size: 14px; color: var(--text-muted); line-height: 1.75; margin: 0; padding-left: 36px;">
              {item.a}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ LIENS EXTERNES UTILISES ═══ -->
  <section style="padding: 60px 0; background: linear-gradient(180deg, #f8f9fa 0%, var(--card-bg) 100%); border-top: 1.5px solid var(--border-color);">
    <div class="container" style="max-width: 950px;">
      <div style="text-align: center; margin-bottom: 40px;">
        <h2 style="font-family: var(--font-heading); font-size: 24px; font-weight: 800; color: var(--primary); margin-bottom: 10px;">
          Ressources Officielles pour vos Travaux de Toiture à {commune.nom}
        </h2>
        <p style="font-size: 15px; color: var(--text-muted);">Organismes officiels, aides et annuaires recommandés pour votre projet en Isère.</p>
      </div>

      <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 16px;">
        {local.externalLinks.map((link) => (
          <a
            href={link.href}
            target="_blank"
            rel="noopener noreferrer"
            style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 18px 20px; text-decoration: none; display: flex; align-items: flex-start; gap: 12px; transition: var(--transition); box-shadow: var(--shadow-sm);"
            class="resource-link"
          >
            <span style="font-size: 22px; flex-shrink: 0;">{link.icon}</span>
            <div>
              <div style="font-weight: 800; color: var(--primary); font-size: 14.5px; margin-bottom: 5px;">{link.label}</div>
              <p style="font-size: 12px; color: var(--text-muted); margin: 0; line-height: 1.5;">{link.description}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ MAILLAGE PROXIMITE ═══ -->
  <section style="padding: 70px 0; background-color: var(--bg); border-top: 1.5px solid var(--border-color);">
    <div class="container">
      <h2 style="font-family: var(--font-heading); font-size: 26px; font-weight: 900; color: var(--primary); text-align: center; margin-bottom: 35px;">
        Travaux de Toiture dans les communes voisines de {commune.nom}
      </h2>
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 15px;">
        {nearby.map((c) => (
          <a
            href={`/toiture-charpente-${c.slug}/`}
            style="background: white; border: 1.5px solid var(--border-color); border-radius: var(--radius-sm); padding: 15px; display: block; text-decoration: none; text-align: center; transition: var(--transition); font-weight: 700; color: var(--primary);"
            class="proximity-link"
          >
            🔨 Toiture &amp; Charpente {c.nom} ({c.codePostal})
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>

<style>
  .proximity-link:hover {
    border-color: var(--secondary);
    background-color: var(--primary-light);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }
  .resource-link:hover {
    border-color: var(--secondary);
    background-color: var(--primary-light);
    transform: translateY(-2px);
    box-shadow: var(--shadow-sm);
  }
</style>
